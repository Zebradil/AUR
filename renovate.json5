{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    "docker:enableMajor",
    "default:automergeAll",
  ],
  // Rebase PRs if needed even if there are commits from other bots
  gitIgnoredAuthors: ["41898282+github-actions[bot]@users.noreply.github.com"],
  packageRules: [{
    matchDatasources: ["docker"],
    matchPackageNames: ["ghcr.io/archlinux/archlinux"],
    // base-20231107.0.190206
    versioning: "regex:^(?<compatibility>.+)-(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<build>\\d+)$",
    // - Going from 20251231 → 20260101 is a numeric jump of 8870 (the
    //   year-boundary makes the integer diff huge even though it's one calendar day).
    //   Every subsequent 20260* tag is at least that far ahead of the pinned
    //   20251231 value.
    // - Renovate's maxMajorIncrement defaults to 500, so every tag from
    //   Jan 2026 onward gets silently filtered as "too big a major bump."
    maxMajorIncrement: 0,
  }],
  customManagers: [{
    customType: "regex",
    managerFilePatterns: ["/^Dockerfile$/"],
    // # renovate: datasource=github-releases depName=Jguer/yay
    // ARG YAY_VERSION=v12.1.1
    matchStrings: [
      "#\\s+renovate:\\s+datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s+(ARG|ENV)\\s+\\S+=['\"]?(?<currentValue>[^'\"\\s]+)['\"]?",
    ]
  }],
}
